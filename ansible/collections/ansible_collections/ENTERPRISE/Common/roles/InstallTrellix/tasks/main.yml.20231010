---
# tasks file for Reinstall_McAfee
- name: Remount /home with exec so we can run ansible scripts (will reset after reboot)
  shell: /usr/bin/mount -o remount,exec "{{ item }}"
  loop:
    - /var/tmp
    - /home
    - /tmp

- name: Check if uninstall script exists
  ansible.builtin.stat:
    path: /opt/McAfee/agent/scripts/uninstall.sh
  register: stat_uninstall

- name: remove McAfee Agent by running uninstall
  ansible.builtin.command: 
    cmd: "sh /opt/McAfee/agent/scripts/uninstall.sh"
  when: stat_uninstall is defined
  register: uninstall
  ignore_errors: yes

- name: Remove the packages if running uninstall doesn't work 
  ansible.builtin.yum:
    name: ['MFEcma', 'MFErt', 'MFEdx'] ## Removing McAfee
    update_cache: yes
    state: absent
  when: uninstall is failed

- name: Ensure the /etc/ma.d directory exists
  ansible.builtin.file:
    path: /etc/ma.d/
    state: directory
    owner: root
    group: root
    mode: 0755

- name: touch the /etc/ma.d/ma_environment.conf file
  ansible.builtin.file:
    path: /etc/ma.d/ma_environment.conf
    state: touch

- name: Grab the capsule server name
  shell: 'rpm -qa | grep katello-ca | cut -d- -f4'
  register: capsule

- name: Create the staging directory
  ansible.builtin.file:
    path: "{{ stage_dir }}"
    state: directory
    mode: '0755'

- name: Check to see if python3 is installed  
  ansible.builtin.yum:  
    name: python39
    state: present

- name: Download the necessary Trellix Binary
  ansible.builtin.get_url:
    url: "https://{{ capsule.stdout }}/{{ repo_loc }}/{{ prd_trellix_bin }}"
    dest: "{{ stage_dir }}"
    owner: "{{ root_user }}"
    group: "{{ root_group }}"
    mode: '0750'
  register: get_flexera
  when: ansible_local['vmInfo']['datacenter'] == "AJPRD" or ansible_local['vmInfo']['datacenter'] == "CSPRD"

- name: Download the necessary Trellix Binary
  ansible.builtin.get_url:
    url: "https://{{ capsule.stdout }}/{{ repo_loc }}/{{ non_trellix_bin }}"
    dest: "{{ stage_dir }}"
    owner: "{{ root_user }}"
    group: "{{ root_group }}"
    mode: '0750'
  register: get_flexera
  when: ansible_local['vmInfo']['datacenter'] == "AJNON" or ansible_local['vmInfo']['datacenter'] == "CSNON"

- name: Try installing Trellix A/V for PROD
  ansible.builtin.shell:
    cmd: "{{ stage_dir }}/{{ prd_trellix_bin }} -i"
  register: av_prd_results
  when: ansible_local['vmInfo']['datacenter'] == "AJPRD" or ansible_local['vmInfo']['datacenter'] == "CSPRD"

- name: Try installing Trellix A/V for NON PRD
  ansible.builtin.shell:
    cmd: "{{ stage_dir }}/{{ non_trellix_bin }} -i"
  register: av_non_results
  when: ansible_local['vmInfo']['datacenter'] == "AJNON" or ansible_local['vmInfo']['datacenter'] == "CSNON"

- name: Check if firewalld is started
  ansible.builtin.command: systemctl is-active firewalld
  register: firewalld
  ignore_errors: yes

- name: Setup required firewall ports so MPO can talk to host
  ansible.posix.firewalld:
    port: "{{ item }}"
    immediate: yes
    permanent: yes
    state: enabled
  loop:
    - 8081/tcp
  when: firewalld.stdout == 'active'
    